{
  "envId": "your-env-id",
  "framework": {
    "name": "uniapp",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "buildCommand": "npm run build:h5",
          "outputPath": "dist/build/h5"
        }
      },
      "functions": {
        "use": "@cloudbase/framework-plugin-function",
        "inputs": {
          "functionRootPath": "./cloudfunctions",
          "functions": [
            {
              "name": "ai-news-crawler",
              "timeout": 60,
              "envVariables": {},
              "runtime": "Nodejs18.15",
              "memorySize": 256,
              "description": "AI新闻爬虫云函数"
            }
          ]
        }
      }
    }
  }
} 